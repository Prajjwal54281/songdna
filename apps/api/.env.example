# Postgres connection (matches docker-compose defaults)
DATABASE_URL=postgres://songdna:songdna@localhost:5432/songdna

# Server
PORT=4000

# Which LLM provider to use. "auto" (default) prefers Anthropic if
# ANTHROPIC_API_KEY is set, else Gemini if GEMINI_API_KEY is set, else falls
# back to a deterministic mock analyzer so the app still runs end-to-end with
# no external dependency at all. Set explicitly to force one: anthropic |
# gemini | mock.
LLM_PROVIDER=auto

# Anthropic (paid). Model used for structured Song DNA extraction.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Gemini (free tier) — get a key at https://aistudio.google.com/apikey, no
# card required for the free quota. This is the default local-dev / demo LLM
# path for budget-conscious prototyping.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Max size (bytes) of an uploaded audio file for real signal analysis.
MAX_AUDIO_UPLOAD_BYTES=20971520
